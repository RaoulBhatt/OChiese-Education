{
  "name": "Canvas LSC",
  "image": "mcr.microsoft.com/devcontainers/ruby:3.1",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "18"
    }
  },
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Canvas LMS",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "echo 'Canvas LMS is cloned. Run ./script/docker_dev_setup.sh to setup.'",
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "32gb"
  }
}
